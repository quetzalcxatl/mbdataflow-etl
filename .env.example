# MBDataFlow_ETL - Environment Variables Template
# Copy this file to .env and fill in real values for local development.
# Never commit .env - it is gitignored.

# GCP
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/your/service-account-key.json

# BigQuery
BQ_DATASET_ID=
BQ_SONDA_PV_TABLE_ID=

# Sonda platform credentials
SONDA_QUERY_USER=
SONDA_QUERY_PASSWORD=
SONDA_PERSONAL_USER=
SONDA_PERSONAL_PASSWORD=

# Drive folder IDs
DRIVE_DESINC_FOLDER_ID=
DRIVE_REPORTES_OPERADOR_FOLDER_ID=
DRIVE_CIRCUITOS_FOLDER_ID=

# CanBus per-brand Drive folders
DRIVE_CANBUS_ALEXANDER_DENNIS=
DRIVE_CANBUS_BYD=
DRIVE_CANBUS_MERCEDES_BENZ=
DRIVE_CANBUS_VOLVO=
DRIVE_CANBUS_YUTONG=
DRIVE_CANBUS_SCANIA=